<header class="header">
  <div class="header__logo">
    <a href="{{ routes.root_url }}">
      <img src="{{ 'logo-comprita-white.svg' | asset_url }}" height="36" alt="Comprita">
    </a>
  </div>

  <ul class="header__nav">
    {%- for link in section.settings.menu.links -%}
      <li>
        <a href="{{ link.url }}">{{ link.title }}</a>
      </li>
    {%- endfor -%}
  </ul>

  <div class="header__icons">
    <a href="{{ routes.account_url }}">
      {% render 'icon-user' %}
    </a>
    <div class="cart-toggle-wrapper relative" style="position: relative;">
      <button class="cart-toggle" aria-label="Cart">
        {% render 'icon-cart' %}
        <span class="cart-count-badge" style="display: {% if cart.item_count > 0 %}flex{% else %}none{% endif %};">
          {{ cart.item_count }}
        </span>
      </button>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
