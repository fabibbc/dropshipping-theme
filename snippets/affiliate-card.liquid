{% comment %}
    Renders an affiliate product card (Mercado Libre)
    Accepts:
    - title: {String} Product title
    - price: {Number} Product price
    - image_url: {String} Product image URL
    - affiliate_link: {String} Affiliate link URL
{% endcomment %}

<div class="product-card affiliate-card bg-white border border-divider rounded-md overflow-hidden hover:border-accent transition-all duration-300 relative" 
     style="background-color: var(--color-white); border: 1px solid var(--color-border); border-radius: 4px; overflow: hidden; transition: all 0.3s; height: 100%; display: flex; flex-direction: column; position: relative;">
  
  <div class="ml-badge absolute top-3 left-3 z-10" style="position: absolute; top: 12px; left: 12px; z-index: 10;">
    <span style="background-color: #FFF3E0; color: #E65100; font-size: 10px; font-weight: 600; padding: 4px 8px; border-radius: 20px; text-transform: uppercase; letter-spacing: 0.05em;">
      Mercado Libre
    </span>
  </div>

  <div class="product-card-image-wrapper block relative aspect-square bg-surface" 
     style="display: block; position: relative; aspect-ratio: 1/1; background-color: var(--color-surface); padding: 12px; overflow: hidden;">
    <img src="{{ image_url }}" 
         alt="{{ title }}" 
         class="w-full h-full object-contain hover:scale-105 transition-transform duration-500" 
         style="width: 100%; height: 100%; object-fit: contain; transition: transform 0.5s;">
  </div>

  <div class="product-card-info p-4 flex flex-col flex-1" style="padding: 16px; flex: 1; display: flex; flex-direction: column;">
    <h3 class="product-card-title text-[14px] font-medium" 
       style="font-size: 14px; font-weight: 500; color: var(--color-carbon); margin-bottom: 8px; line-height: 1.4;">
      {{ title }}
    </h3>
    
    <div class="product-card-footer mt-auto pt-4" style="margin-top: auto; padding-top: 16px;">
      <p class="product-card-price text-accent font-medium text-[15px] mb-4" style="color: var(--color-accent); font-size: 15px; font-weight: 500; margin-bottom: 16px;">
        {{ price | money }}
      </p>

      <a href="{{ affiliate_link }}" target="_blank" rel="nofollow" 
              class="btn btn-secondary w-full flex items-center justify-center gap-2" 
              style="width: 100%; display: flex; align-items: center; justify-content: center; gap: 8px;">
        Ver en Mercado Libre →
      </a>
    </div>
  </div>
</div>
